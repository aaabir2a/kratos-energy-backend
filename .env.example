# docker compose host-port bindings (bound to 127.0.0.1 only).
# Change these if 4000 / 8080 clash with another project on the VPS —
# then update your host nginx proxy_pass ports to match.
API_PORT=4000
WEB_PORT=8080

# Backend origin baked into the CRM frontend build.
#  - Leave empty  → CRM calls same-origin /api/v1 (proxied internally, no CORS).
#  - Set absolute → CRM calls the API domain directly (needs that origin in the
#                   backend CORS_ORIGINS). e.g. https://api.kratos-energy.com/api/v1
VITE_API_BASE_URL=https://api.kratos-energy.com/api/v1
