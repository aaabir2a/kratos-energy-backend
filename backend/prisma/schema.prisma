// Kratos Energy CRM — Prisma schema
// Phase 1: Authentication, RBAC, Offices.
// Tables grow phase-by-phase (Phase 2 leads, Phase 4 deals, etc.).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Offices — multi-office tenancy boundary
// ─────────────────────────────────────────────────────────────
model Office {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  code      String    @unique
  timezone  String    @default("Australia/Sydney")
  phone     String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  users User[]
  leads Lead[]

  @@index([isActive])
  @@map("offices")
}

// ─────────────────────────────────────────────────────────────
// RBAC — roles, permissions, join
// ─────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique // admin | manager | marketing | sales
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid()) @db.Uuid
  resource  String // leads | deals | users | ...
  action    String // read | write | delete | export | approve | manage
  slug      String   @unique // e.g. "leads.read"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// Users — staff accounts
// ─────────────────────────────────────────────────────────────
model User {
  id               String    @id @default(uuid()) @db.Uuid
  officeId         String?   @map("office_id") @db.Uuid
  roleId           String    @map("role_id") @db.Uuid
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  email            String    @unique
  passwordHash     String    @map("password_hash")
  phone            String?
  avatarUrl        String?   @map("avatar_url")
  isActive         Boolean   @default(true) @map("is_active")
  emailVerifiedAt  DateTime? @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz(6)
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  office        Office?        @relation(fields: [officeId], references: [id], onDelete: SetNull)
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  refreshTokens RefreshToken[]
  sessions      UserSession[]
  auditLogs     AuditLog[]

  // Phase 2 — leads
  assignedLeads       Lead[]              @relation("LeadAssignee")
  createdLeads        Lead[]              @relation("LeadCreatedBy")
  leadNotes           LeadNote[]
  leadActivities      LeadActivity[]
  leadStatusChanges   LeadStatusHistory[]
  assignmentsReceived LeadAssignment[]    @relation("AssignmentTo")
  assignmentsMade     LeadAssignment[]    @relation("AssignmentBy")
  tasks               Task[]              @relation("TaskAssignee")
  createdTasks        Task[]              @relation("TaskCreatedBy")

  @@index([officeId])
  @@index([roleId])
  @@index([isActive])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Sessions & refresh tokens
// ─────────────────────────────────────────────────────────────
model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedBy String?   @map("replaced_by") @db.Uuid
  userAgent  String?   @map("user_agent")
  ip         String?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model UserSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  ip         String?
  userAgent  String?   @map("user_agent")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// ─────────────────────────────────────────────────────────────
// Audit log — immutable trail of sensitive mutations
// ─────────────────────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String // e.g. "user.create", "role.update"
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═════════════════════════════════════════════════════════════
// PHASE 2 — Leads & Assignment
// ═════════════════════════════════════════════════════════════

enum LeadStatus {
  OPEN
  CONVERTED
  LOST
  JUNK
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum PipelineTrack {
  LEAD
  DEAL
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  SMS
  MEETING
  STAGE_CHANGE
  ASSIGNMENT
  SYSTEM
}

enum AssignmentMethod {
  MANUAL
  AUTO_ROUND_ROBIN
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

// Channel a lead came from (Website, Facebook, Chatbot, Referral, Manual...).
model LeadSource {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  type      String   @default("other") // website | social | chatbot | referral | manual | other
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  leads        Lead[]
  attributions LeadAttribution[]

  @@map("lead_sources")
}

// Configurable pipeline stages. LEAD track for pre-conversion; DEAL track (Phase 4).
model PipelineStage {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  slug      String        @unique
  track     PipelineTrack @default(LEAD)
  order     Int           @default(0)
  color     String?
  isDefault Boolean       @default(false) @map("is_default")
  isWon     Boolean       @default(false) @map("is_won")
  isLost    Boolean       @default(false) @map("is_lost")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  leads Lead[]

  @@index([track, order])
  @@map("pipeline_stages")
}

model Lead {
  id           String  @id @default(uuid()) @db.Uuid
  officeId     String? @map("office_id") @db.Uuid
  leadSourceId String? @map("lead_source_id") @db.Uuid
  stageId      String? @map("stage_id") @db.Uuid
  assignedToId String? @map("assigned_to") @db.Uuid
  createdById  String? @map("created_by") @db.Uuid
  campaignId   String? @map("campaign_id") @db.Uuid

  firstName      String  @map("first_name")
  lastName       String  @map("last_name")
  email          String?
  phone          String?
  secondaryPhone String? @map("secondary_phone")

  addressLine String? @map("address_line")
  suburb      String?
  state       String?
  postcode    String?

  propertyType        String? @map("property_type")
  roofType            String? @map("roof_type")
  estimatedSystemSize String? @map("estimated_system_size")

  status         LeadStatus   @default(OPEN)
  priority       LeadPriority @default(MEDIUM)
  score          Int          @default(0)
  lostReason     String?      @map("lost_reason")
  nextFollowUpAt DateTime?    @map("next_follow_up_at") @db.Timestamptz(6)
  convertedAt    DateTime?    @map("converted_at") @db.Timestamptz(6)

  leadType      String? @map("lead_type")
  utmSource     String? @map("utm_source")
  utmMedium     String? @map("utm_medium")
  utmCampaign   String? @map("utm_campaign")
  utmTerm       String? @map("utm_term")
  utmContent    String? @map("utm_content")
  referrerUrl   String? @map("referrer_url")
  landingPageId String? @map("landing_page_id") @db.Uuid
  ipAddress     String? @map("ip_address")
  userAgent     String? @map("user_agent")

  consentMarketing    Boolean @default(false) @map("consent_marketing")
  customFormResponses Json    @default("{}") @map("custom_form_responses")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  office     Office?        @relation(fields: [officeId], references: [id], onDelete: SetNull)
  source     LeadSource?    @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  stage      PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  assignedTo User?          @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?          @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  notes         LeadNote[]
  activities    LeadActivity[]
  statusHistory LeadStatusHistory[]
  assignments   LeadAssignment[]
  tasks         Task[]

  // Phase 3
  campaign        MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  attributions    LeadAttribution[]
  chatbotSession  ChatbotSession?
  formSubmissions FormSubmission[]

  @@index([campaignId])
  @@index([officeId])
  @@index([stageId])
  @@index([assignedToId])
  @@index([leadSourceId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedToId, stageId])
  @@index([email])
  @@index([phone])
  @@map("leads")
}

model LeadNote {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  authorId  String?  @map("author_id") @db.Uuid
  body      String
  isPinned  Boolean  @default(false) @map("is_pinned")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  lead   Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@map("lead_notes")
}

model LeadActivity {
  id         String       @id @default(uuid()) @db.Uuid
  leadId     String       @map("lead_id") @db.Uuid
  userId     String?      @map("user_id") @db.Uuid
  type       ActivityType
  subject    String?
  body       String?
  metadata   Json?
  occurredAt DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(6)

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, occurredAt])
  @@map("lead_activities")
}

model LeadStatusHistory {
  id          String   @id @default(uuid()) @db.Uuid
  leadId      String   @map("lead_id") @db.Uuid
  fromStageId String?  @map("from_stage_id") @db.Uuid
  toStageId   String?  @map("to_stage_id") @db.Uuid
  changedById String?  @map("changed_by") @db.Uuid
  reason      String?
  changedAt   DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  lead      Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  changedBy User? @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([leadId, changedAt])
  @@map("lead_status_history")
}

model LeadAssignment {
  id           String           @id @default(uuid()) @db.Uuid
  leadId       String           @map("lead_id") @db.Uuid
  assignedToId String           @map("assigned_to") @db.Uuid
  assignedById String?          @map("assigned_by") @db.Uuid
  method       AssignmentMethod @default(MANUAL)
  assignedAt   DateTime         @default(now()) @map("assigned_at") @db.Timestamptz(6)

  lead       Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User  @relation("AssignmentTo", fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("AssignmentBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([leadId, assignedAt])
  @@index([assignedToId])
  @@map("lead_assignments")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  leadId      String?    @map("lead_id") @db.Uuid
  assigneeId  String     @map("assignee_id") @db.Uuid
  createdById String?    @map("created_by") @db.Uuid
  title       String
  description String?
  dueAt       DateTime?  @map("due_at") @db.Timestamptz(6)
  status      TaskStatus @default(OPEN)
  completedAt DateTime?  @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  lead      Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee  User  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdBy User? @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([assigneeId, dueAt])
  @@index([leadId])
  @@index([status])
  @@map("tasks")
}

// ═════════════════════════════════════════════════════════════
// PHASE 3 — Source Tracking & Intake
// ═════════════════════════════════════════════════════════════

enum TouchType {
  FIRST
  LAST
}

enum SubmissionStatus {
  ACCEPTED
  DUPLICATE
  REJECTED
}

// Campaign + spend, for cost-per-lead / ROI reporting.
model MarketingCampaign {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  channel     String? // facebook | google | tiktok | email | other
  utmCampaign String?   @map("utm_campaign")
  budget      Decimal?  @db.Decimal(12, 2)
  spend       Decimal?  @db.Decimal(12, 2)
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  leads        Lead[]
  attributions LeadAttribution[]

  @@index([utmCampaign])
  @@map("marketing_campaigns")
}

// Immutable attribution rows. First touch written once at capture;
// every re-submission appends a LAST touch. Never overwritten.
model LeadAttribution {
  id            String    @id @default(uuid()) @db.Uuid
  leadId        String    @map("lead_id") @db.Uuid
  leadSourceId  String?   @map("lead_source_id") @db.Uuid
  campaignId    String?   @map("campaign_id") @db.Uuid
  landingPageId String?   @map("landing_page_id") @db.Uuid
  touchType     TouchType @default(FIRST) @map("touch_type")
  utmSource     String?   @map("utm_source")
  utmMedium     String?   @map("utm_medium")
  utmCampaign   String?   @map("utm_campaign")
  utmTerm       String?   @map("utm_term")
  utmContent    String?   @map("utm_content")
  gclid         String?
  fbclid        String?
  referrerUrl   String?   @map("referrer_url")
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  raw           Json?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  lead     Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  source   LeadSource?        @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  campaign MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([leadSourceId, createdAt])
  @@index([campaignId])
  @@map("lead_attributions")
}

// Chatbot conversation that produced a lead.
model ChatbotSession {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @unique @map("session_id")
  leadId     String?  @unique @map("lead_id") @db.Uuid
  botVersion String?  @map("bot_version")
  transcript Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@map("chatbot_sessions")
}

// Raw record of every public form/webhook submission (audit, even dupes).
model FormSubmission {
  id         String           @id @default(uuid()) @db.Uuid
  leadId     String?          @map("lead_id") @db.Uuid
  channel    String // web | social:<platform> | chatbot
  status     SubmissionStatus @default(ACCEPTED)
  rawPayload Json             @map("raw_payload")
  ipAddress  String?          @map("ip_address")
  userAgent  String?          @map("user_agent")
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([channel, createdAt])
  @@index([leadId])
  @@map("form_submissions")
}
