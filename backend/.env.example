# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=Kratos CRM API
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://kratos:kratos@localhost:5432/kratos_crm?schema=public

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Security ──────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

# ── Seed admin (first boot) ───────────────────────────
SEED_ADMIN_EMAIL=admin@kratosenergy.com.au
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=System Admin

# Intake webhooks (social/chatbot)
INTAKE_WEBHOOK_SECRET=change_me_webhook_secret_16+
