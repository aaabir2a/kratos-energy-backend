# Copy to backend/.env on the server and fill in real values.
# NEVER commit the real .env (it is gitignored).

NODE_ENV=production
PORT=4000
APP_NAME=Kratos CRM API
API_PREFIX=/api/v1

# Origins allowed to call the API cross-site. The public marketing site needs
# this; the CRM is same-origin (served with its own /api proxy) so it doesn't.
CORS_ORIGINS=https://kratos-energy.com,https://www.kratos-energy.com,https://crm.kratos-energy.com

# LIVE database — do NOT start a Postgres container, reuse the existing one.
#  - If Postgres runs on THIS VPS host: use host.docker.internal (mapped to the
#    host gateway in docker-compose.yml). Ensure pg_hba.conf allows the docker
#    subnet and postgres listens on the docker bridge (listen_addresses).
#  - If the DB is on a different machine: use its host/IP directly.
# Password kratos@2026 → @ must be URL-encoded as %40. Port is 5432 (NOT 5433).
DATABASE_URL=postgresql://kratos:kratos%402026@host.docker.internal:5432/kratos-backend

# Required. Points at the internal redis service from docker-compose.
REDIS_URL=redis://redis:6379

# Generate fresh secrets: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_32+_chars
JWT_REFRESH_SECRET=CHANGE_ME_32+_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

# Seed admin (used only by `npx tsx prisma/seed.ts` on a fresh DB).
SEED_ADMIN_EMAIL=admin@kratosenergy.com.au
SEED_ADMIN_PASSWORD=CHANGE_ME_strong
SEED_ADMIN_NAME=System Admin

# openssl rand -hex 24
INTAKE_WEBHOOK_SECRET=CHANGE_ME

# MinIO / object storage. MINIO_ENDPOINT must be a PUBLIC host — image URLs are
# returned to the marketing site, so 127.0.0.1 will not work here.
MINIO_ENDPOINT=your-minio-host-or-ip
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=kratos-uploads

# Chatbot platform integration (optional — omit if unused).
# CHATBOT_API_BASE=https://api.ambrosianuk.com
# CHATBOT_CRM_KEY=CHANGE_ME
# CHATBOT_WEBHOOK_SECRET=CHANGE_ME
